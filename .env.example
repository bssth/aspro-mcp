# Your Aspro.Cloud subdomain — the {company} part of https://{company}.aspro.cloud
ASPRO_COMPANY=your_company

# Server API key (passed as ?api_key=... on every request)
ASPRO_API_KEY=your_api_key_here

# Optional: override base URL entirely. If unset, built from ASPRO_COMPANY.
# ASPRO_BASE_URL=https://your_company.aspro.cloud/api/v1/module

# Optional: request timeout in ms (default 30000)
# ASPRO_TIMEOUT_MS=30000
